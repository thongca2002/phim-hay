<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Phim360</title>

<style>
body{
margin:0;
font-family:Arial;
background:#0f0f0f;
color:white;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:15px;
background:#000;
position:sticky;
top:0;
}

.logo{
color:#01b4e4;
font-size:22px;
font-weight:bold;
}

input{
padding:8px;
border:none;
border-radius:5px;
width:200px;
}

.banner{
padding:25px;
text-align:center;
background:linear-gradient(90deg,#000,#111,#01b4e4);
}

.container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
gap:12px;
padding:15px;
}

.movie{
background:#222;
border-radius:10px;
overflow:hidden;
cursor:pointer;
transition:0.3s;
}

.movie:hover{
transform:scale(1.05);
border:2px solid #01b4e4;
}

.movie img{
width:100%;
height:240px;
object-fit:cover;
}

.title{
padding:8px;
font-size:14px;
}

#player{
display:none;
position:fixed;
top:0;left:0;
width:100%;
height:100%;
background:black;
z-index:999;
}

#player iframe{
width:100%;
height:100%;
}

.close{
position:absolute;
top:10px;
right:10px;
background:#01b4e4;
border:none;
padding:10px;
color:black;
cursor:pointer;
font-weight:bold;
}
</style>
</head>

<body>

<header>
<div class="logo">🎬 PHIM360</div>
<input id="search" placeholder="Tìm phim...">
</header>

<div class="banner">
🔥 Kho phim tự động từ TMDB – xem trailer nhanh – giao diện Netflix mini
</div>

<div class="container" id="list"></div>

<!-- PLAYER -->
<div id="player">
<button class="close" onclick="closePlayer()">X</button>
<iframe id="video"></iframe>
</div>

<script>

/* 🔑 BEARER TOKEN TMDB (BẠN ĐÃ GỬI) */
const API = "eyJhbGciOiJIUzI1NiJ9.eyJhdWQiOiJlMjFhODVlNjM0M2Q0OTVmN2U4MmVkZmZjM2YyMWQ2NyIsIm5iZiI6MTc3ODc2ODExMi4zNzc5OTk4LCJzdWIiOiI2YTA1ZDhmMDE3MDZkMjkxZjA1ODA1NWYiLCJzY29wZXMiOlsiYXBpX3JlYWQiXSwidmVyc2lvbiI6MX0.ZD0DXp2qLkYSTQD91KhRMAV19CS6ScNaH--IAodQeM0";

let store = [];

/* 🔥 LẤY PHIM */
fetch("https://api.themoviedb.org/3/trending/movie/day", {
  headers: {
    Authorization: `Bearer ${API}`,
    "Content-Type": "application/json"
  }
})
.then(r => r.json())
.then(data => {
  store = data.results;
  render(store);
});

/* 🎬 HIỂN THỊ */
function render(list){
let html="";
list.forEach(m=>{
html+=`
<div class="movie" onclick="openMovie(${m.id})">
<img src="https://image.tmdb.org/t/p/w500${m.poster_path}">
<div class="title">${m.title}</div>
</div>`;
});
document.getElementById("list").innerHTML=html;
}

/* 🎞 TRAILER */
function openMovie(id){
fetch(`https://api.themoviedb.org/3/movie/${id}/videos`, {
  headers: {
    Authorization: `Bearer ${API}`
  }
})
.then(r=>r.json())
.then(v=>{
let key = v.results[0]?.key;
if(key){
document.getElementById("player").style.display="block";
document.getElementById("video").src=`https://www.youtube.com/embed/${key}`;
}
});
}

/* ❌ ĐÓNG */
function closePlayer(){
document.getElementById("player").style.display="none";
document.getElementById("video").src="";
}

/* 🔍 SEARCH */
document.getElementById("search").addEventListener("input",function(){
let val=this.value.toLowerCase();
render(store.filter(m=>m.title.toLowerCase().includes(val)));
});

</script>

</body>
</html>
